#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

// Insert at Head - O(1)
void insertHead(Node*& head, int value) {
    Node* newNode = new Node;
    newNode->data = value;
    newNode->next = head;
    head = newNode;
}

// Insert at Tail - O(n)
void insertTail(Node*& head, int value) {
    Node* newNode = new Node;
    newNode->data = value;
    newNode->next = NULL;

    if (head == NULL) {
        head = newNode;
        return;
    }

    Node* temp = head;
    while (temp->next != NULL)
        temp = temp->next;

    temp->next = newNode;
}

// Delete by Value - O(n)
void deleteNode(Node*& head, int value) {
    if (head == NULL)
        return;

    if (head->data == value) {
        Node* temp = head;
        head = head->next;
        delete temp;
        return;
    }

    Node* current = head;

    while (current->next != NULL && current->next->data != value)
        current = current->next;

    if (current->next != NULL) {
        Node* temp = current->next;
        current->next = temp->next;
        delete temp;
    }
}

// Traverse and Print - O(n)
void display(Node* head) {
    cout << "Linked List: ";

    while (head != NULL) {
        cout << head->data << " ";
        head = head->next;
    }

    cout << endl;
}

int main() {
    Node* head = NULL;

    cout << "Insert at Head: 20" << endl;
    insertHead(head, 20);
    display(head);

    cout << "Insert at Head: 10" << endl;
    insertHead(head, 10);
    display(head);

    cout << "Insert at Tail: 30" << endl;
    insertTail(head, 30);
    display(head);

    cout << "Insert at Tail: 40" << endl;
    insertTail(head, 40);
    display(head);

    cout << "Delete value 20" << endl;
    deleteNode(head, 20);
    display(head);

    return 0;
}

